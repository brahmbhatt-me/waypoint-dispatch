generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

enum TripStatus {
  OPEN
  GENERATING
  LOCKED
  COMPLETED
}

enum PickupPreference {
  RUGGLES
  DRIVER
}

model User {
  id             String   @id @default(cuid())
  name           String
  phone          String   @unique
  email          String?  @unique
  role           Role     @default(PASSENGER)
  defaultAddress String?
  defaultLat     Float?
  defaultLng     Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attendances    Attendance[]
  driverSessions DriverSession[]
  addressHistory AddressHistory[]

  @@map("users")
}

model Trip {
  id        String     @id @default(cuid())
  date      DateTime   @unique
  status    TripStatus @default(OPEN)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  attendances    Attendance[]
  driverSessions DriverSession[]
  assignments    Assignment[]

  @@map("trips")
}

model Attendance {
  id               String           @id @default(cuid())
  userId           String
  tripId           String
  dropoffAddress   String
  dropoffLat       Float?
  dropoffLng       Float?
  pickupPreference PickupPreference @default(RUGGLES)
  pickupAddress    String?
  pickupLat        Float?
  pickupLng        Float?
  notes            String?
  attending        Boolean          @default(true)
  markedAbsent     Boolean          @default(false)
  confirmedAddress Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user         User        @relation(fields: [userId], references: [id])
  trip         Trip        @relation(fields: [tripId], references: [id])
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  @@unique([userId, tripId])
  @@map("attendances")
}

model DriverSession {
  id           String   @id @default(cuid())
  userId       String
  tripId       String
  seats        Int
  carType      String?
  startAddress String?
  startLat     Float?
  startLng     Float?
  available    Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  trip       Trip        @relation(fields: [tripId], references: [id])
  assignment Assignment?

  @@unique([userId, tripId])
  @@map("driver_sessions")
}

model Assignment {
  id               String   @id @default(cuid())
  tripId           String
  driverSessionId  String   @unique
  stopOrder        Json?
  mapsUrl          String?
  goingMapsUrl     String?
  estimatedMinutes Int?
  isLocked         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trip          Trip          @relation(fields: [tripId], references: [id])
  driverSession DriverSession @relation(fields: [driverSessionId], references: [id])
  passengers    Attendance[]

  @@map("assignments")
}

model AddressHistory {
  id      String   @id @default(cuid())
  userId  String
  address String
  lat     Float?
  lng     Float?
  usedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("address_history")
}
