# ─────────────────────────────────────────────────────────────────────────────
# Database (Supabase or any PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# Google Maps APIs
# ─────────────────────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/
# Enable: Geocoding API, Maps JavaScript API, Directions API, Places API
# Restrict key to your domain in production!
GOOGLE_MAPS_API_KEY="AIzaSy..."

# Also expose to frontend for Places Autocomplete widget (optional)
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIzaSy..."

# ─────────────────────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────────────────────
# Change this to a real secure passcode!
ADMIN_PASSCODE="baps2024"
NEXT_PUBLIC_ADMIN_CODE="baps2024"

# ─────────────────────────────────────────────────────────────────────────────
# App URL (for generating shareable links)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
